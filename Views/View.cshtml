@using Dnn.Modules.Newsletters.Models
@using DNNConnect.CKEditorProvider.Web
@using DotNetNuke.Web.MvcPipeline.Modules
@model NewsletterViewModel
@functions {
    const string NewsletterResourceFile = "~/DesktopModules/Admin/Newsletters/App_LocalResources/Newsletter.ascx.resx";
    string L(string key)
    {
        return DotNetNuke.Services.Localization.Localization.GetString(key, NewsletterResourceFile);
    }
}

@*
    All class names are prefixed with "nl-" so they cannot collide with or be
    affected by DotNetNuke's global dnn.css / form.css / dnnCheckbox plugin.
    No "dnnForm", "dnnFormItem", "dnnLabel", "dnnPrimaryAction", "dnnCheckbox"
    classes appear here, which prevents DNN's auto-attached widgets and the
    inherited margins / orange validation highlight.
*@
<div class="nl-module"
     id="nl-module-@Model.ModuleId"
     data-moduleid="@Model.ModuleId"
     data-initial-entries="@Html.Raw(HttpUtility.HtmlAttributeEncode(Model.InitialEntries ?? "[]"))"
     data-text-noresults="@L("NoResults")"
     data-text-searching="@L("Searching")"
     data-text-confirmsend="@L("ConfirmSend")"
     data-text-norecipients="@L("ConfirmNoRecipients")">

    <div class="nl-status" role="status" aria-live="polite" aria-atomic="true">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="@Model.StatusCssClass">@Model.StatusMessage</div>
        }
    </div>

    <ul class="nl-tabs" role="tablist">
        <li class="nl-tab nl-tab-active" role="tab" data-target="#nl-panel-message-@Model.ModuleId" tabindex="0">@L("Message")</li>
        <li class="nl-tab" role="tab" data-target="#nl-panel-advanced-@Model.ModuleId" tabindex="-1">@L("AdvancedSettings")</li>
    </ul>

    <div id="nl-form-@Model.ModuleId" class="nl-form">

        <div class="nl-panel nl-panel-active" id="nl-panel-message-@Model.ModuleId" role="tabpanel">
            <fieldset class="nl-fieldset">
                <div class="nl-row">
                    <div class="nl-label">
                        <label for="recipients_@Model.ModuleId">@L("plRoles") <span aria-hidden="true" class="nl-required">*</span></label>
                    </div>
                    <div class="nl-control">
                        <input type="text" id="recipients_@Model.ModuleId" name="Recipients" value="@Model.Recipients" class="nl-input" />
                    </div>
                </div>

                @if (Model.LanguagesVisible && Model.AvailableLanguages.Count > 0)
                {
                    <div class="nl-row">
                        <div class="nl-label">
                            <label>@L("plLanguages")</label>
                        </div>
                        <div class="nl-control">
                            <ul class="nl-lang">
                                @foreach (var language in Model.AvailableLanguages)
                                {
                                    <li>
                                        <label class="nl-check-label">
                                            <input type="checkbox" name="SelectedLanguages" value="@language.Value" @(language.Selected ? "checked=\"checked\"" : string.Empty) class="nl-checkbox" />
                                            <span>@language.Text</span>
                                        </label>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="AdditionalEmails_@Model.ModuleId">@L("plEmail")</label>
                    </div>
                    <div class="nl-control">
                        <textarea id="AdditionalEmails_@Model.ModuleId" name="AdditionalEmails" rows="3" class="nl-input nl-textarea">@Model.AdditionalEmails</textarea>
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="From_@Model.ModuleId">@L("plFrom")</label>
                    </div>
                    <div class="nl-control">
                        <input type="text" id="From_@Model.ModuleId" name="From" maxlength="100" value="@Model.From" class="nl-input" />
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="ReplyTo_@Model.ModuleId">@L("plReplyTo")</label>
                    </div>
                    <div class="nl-control">
                        <input type="text" id="ReplyTo_@Model.ModuleId" name="ReplyTo" maxlength="100" value="@Model.ReplyTo" class="nl-input" />
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="Subject_@Model.ModuleId">@L("plSubject") <span aria-hidden="true" class="nl-required">*</span></label>
                    </div>
                    <div class="nl-control">
                        <input type="text" id="Subject_@Model.ModuleId" name="Subject" maxlength="100" value="@Model.Subject" required="required" aria-required="true" class="nl-input" />
                    </div>
                </div>

                <div class="nl-row nl-row-ck">
                    <div class="nl-label">
                        <label for="Message">@L("Message") <span aria-hidden="true" class="nl-required">*</span></label>
                    </div>
                    <div class="nl-control nl-ck">
                        @Html.CKEditorEditorFor(x => x.Message, Model.ModuleId)
                    </div>
                </div>
            </fieldset>
        </div>

        <div class="nl-panel" id="nl-panel-advanced-@Model.ModuleId" role="tabpanel" hidden>
            <fieldset class="nl-fieldset">
                @Html.Partial("~/DesktopModules/Admin/Newsletters/Views/Shared/_AttachmentPicker.cshtml", Model.Attachment)

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="ReplaceTokens_@Model.ModuleId">@L("plReplaceTokens")</label>
                    </div>
                    <div class="nl-control">
                        <label class="nl-check-label">
                            <input type="checkbox" id="ReplaceTokens_@Model.ModuleId" name="ReplaceTokens" @(Model.ReplaceTokens ? "checked=\"checked\"" : string.Empty) class="nl-checkbox" />
                        </label>
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="Priority_@Model.ModuleId">@L("plPriority")</label>
                    </div>
                    <div class="nl-control">
                        <select id="Priority_@Model.ModuleId" name="Priority" class="nl-input nl-select">
                            <option value="1" @(Model.Priority == "1" ? "selected=\"selected\"" : string.Empty)>@L("High")</option>
                            <option value="2" @(Model.Priority == "2" ? "selected=\"selected\"" : string.Empty)>@L("Normal")</option>
                            <option value="3" @(Model.Priority == "3" ? "selected=\"selected\"" : string.Empty)>@L("Low")</option>
                        </select>
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label for="SendMethod_@Model.ModuleId">@L("plSendMethod")</label>
                    </div>
                    <div class="nl-control">
                        <select id="SendMethod_@Model.ModuleId" name="SendMethod" class="nl-input nl-select">
                            <option value="TO" @(Model.SendMethod == "TO" ? "selected=\"selected\"" : string.Empty)>@L("SendTo")</option>
                            <option value="BCC" @(Model.SendMethod == "BCC" ? "selected=\"selected\"" : string.Empty)>@L("SendBCC")</option>
                            <option value="RELAY" @(Model.SendMethod == "RELAY" ? "selected=\"selected\"" : string.Empty)>@L("SendRelay")</option>
                        </select>
                    </div>
                </div>

                <div class="nl-row nl-relay-row" @(Model.RelayAddressVisible ? "" : "hidden")>
                    <div class="nl-label">
                        <label for="RelayAddress_@Model.ModuleId">@L("plRelayAddress")</label>
                    </div>
                    <div class="nl-control">
                        <input type="text" id="RelayAddress_@Model.ModuleId" name="RelayAddress" maxlength="100" value="@Model.RelayAddress" class="nl-input" />
                    </div>
                </div>

                <div class="nl-row">
                    <div class="nl-label">
                        <label>@L("plSendAction")</label>
                    </div>
                    <div class="nl-control nl-radios">
                        <label class="nl-check-label">
                            <input type="radio" id="Sendaction-S_@Model.ModuleId" name="SendAction" value="S" @(Model.SendAction == "S" ? "checked=\"checked\"" : string.Empty) class="nl-radio" />
                            <span>@L("Synchronous")</span>
                        </label>
                        <label class="nl-check-label">
                            <input type="radio" id="Sendaction-A_@Model.ModuleId" name="SendAction" value="A" @(Model.SendAction == "A" ? "checked=\"checked\"" : string.Empty) class="nl-radio" />
                            <span>@L("Asynchronous")</span>
                        </label>
                    </div>
                </div>
            </fieldset>
        </div>

        <ul class="nl-actions">
            <li><button type="button" class="nl-btn nl-btn-primary nl-btn-send">@L("cmdSend")</button></li>
            <li><button type="button" class="nl-btn nl-btn-secondary nl-btn-preview">@L("cmdPreview")</button></li>
            <li class="nl-spinner" aria-hidden="true" hidden><span class="nl-spinner-icon"></span></li>
        </ul>

        <div class="nl-preview" hidden>
            <dl class="nl-preview-list">
                <dt>@L("Preview")</dt>
                <dd></dd>
                <dt>@L("plSubject")</dt>
                <dd class="nl-preview-subject"></dd>
                <dt>@L("Message")</dt>
                <dd class="nl-preview-body"></dd>
            </dl>
            <ul class="nl-actions">
                <li><button type="button" class="nl-btn nl-btn-secondary nl-btn-cancel-preview">@L("cmdCancelPreview")</button></li>
            </ul>
        </div>

    </div>
</div>
