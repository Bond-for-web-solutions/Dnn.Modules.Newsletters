@using Dnn.Modules.Newsletters.Models
@using DNNConnect.CKEditorProvider.Web
@using DotNetNuke.Web.MvcPipeline.Modules
@model NewsletterViewModel
@functions {
    // Centralize all view localization through the WebForms control's resource
    // file so we maintain a single set of resx files (Newsletter.ascx.resx).
    const string NewsletterResourceFile = "~/DesktopModules/Admin/Newsletters/App_LocalResources/Newsletter.ascx.resx";
    string L(string key)
    {
        return DotNetNuke.Services.Localization.Localization.GetString(key, NewsletterResourceFile);
    }
}

<div class="dnnForm dnnNewsletters dnnClear"
     id="dnnNewsletters_@Model.ModuleId"
     data-moduleid="@Model.ModuleId"
     data-initial-entries="@Html.Raw(HttpUtility.HtmlAttributeEncode(Model.InitialEntries ?? "[]"))"
     data-text-noresults="@L("NoResults")"
     data-text-searching="@L("Searching")"
     data-text-confirmsend="@L("ConfirmSend")"
     data-text-norecipients="@L("ConfirmNoRecipients")">

    <div class="status-area" role="status" aria-live="polite" aria-atomic="true">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="@Model.StatusCssClass">@Model.StatusMessage</div>
        }
    </div>

    <ul class="dnnAdminTabNav dnnClear">
        <li><a href="#newMessage_@Model.ModuleId">@L("Message")</a></li>
        <li><a href="#newAdvancedSettings_@Model.ModuleId">@L("AdvancedSettings")</a></li>
    </ul>

    <div id="newsletterForm_@Model.ModuleId" class="newsletter-form">

        <div class="newMessage" id="newMessage_@Model.ModuleId">
            <fieldset>
                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="recipients_@Model.ModuleId">@L("plRoles")</label>
                    </div>
                    <input type="text" id="recipients_@Model.ModuleId" name="Recipients" value="@Model.Recipients" />
                </div>

                @if (Model.LanguagesVisible && Model.AvailableLanguages.Count > 0)
                {
                    <div class="dnnFormItem">
                        <div class="dnnLabel" style="position:relative">
                            <label>@L("plLanguages")</label>
                        </div>
                        <div class="dnnLangSelector">
                            <ul>
                                @foreach (var language in Model.AvailableLanguages)
                                {
                                    <li>
                                        <label>
                                            <input type="checkbox" name="SelectedLanguages" value="@language.Value" @(language.Selected ? "checked=\"checked\"" : string.Empty) />
                                            @language.Text
                                        </label>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="AdditionalEmails_@Model.ModuleId">@L("plEmail")</label>
                    </div>
                    <textarea id="AdditionalEmails_@Model.ModuleId" name="AdditionalEmails" rows="3" class="noResize">@Model.AdditionalEmails</textarea>
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="From_@Model.ModuleId">@L("plFrom")</label>
                    </div>
                    <input type="text" id="From_@Model.ModuleId" name="From" maxlength="100" value="@Model.From" />
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="ReplyTo_@Model.ModuleId">@L("plReplyTo")</label>
                    </div>
                    <input type="text" id="ReplyTo_@Model.ModuleId" name="ReplyTo" maxlength="100" value="@Model.ReplyTo" />
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="Subject_@Model.ModuleId">@L("plSubject") <span aria-hidden="true" class="required-marker">*</span></label>
                    </div>
                    <input type="text" id="Subject_@Model.ModuleId" name="Subject" maxlength="100" value="@Model.Subject" required="required" aria-required="true" />
                </div>

                <div class="dnnFormItem ckediv">
                    <div class="dnnLabel" style="position:relative">
                        <label for="Message">@L("Message") <span aria-hidden="true" class="required-marker">*</span></label>
                    </div>
                    @Html.CKEditorEditorFor(x => x.Message, Model.ModuleId)
                </div>
            </fieldset>
        </div>

        <div class="newAdvancedSettings" id="newAdvancedSettings_@Model.ModuleId">
            <fieldset>
                @Html.Partial("~/DesktopModules/Admin/Newsletters/Views/Shared/_AttachmentPicker.cshtml", Model.Attachment)

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="ReplaceTokens_@Model.ModuleId">@L("plReplaceTokens")</label>
                    </div>
                    <input type="checkbox" id="ReplaceTokens_@Model.ModuleId" name="ReplaceTokens" @(Model.ReplaceTokens ? "checked=\"checked\"" : string.Empty) />
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="Priority_@Model.ModuleId">@L("plPriority")</label>
                    </div>
                    <select id="Priority_@Model.ModuleId" name="Priority">
                        <option value="1" @(Model.Priority == "1" ? "selected=\"selected\"" : string.Empty)>@L("High")</option>
                        <option value="2" @(Model.Priority == "2" ? "selected=\"selected\"" : string.Empty)>@L("Normal")</option>
                        <option value="3" @(Model.Priority == "3" ? "selected=\"selected\"" : string.Empty)>@L("Low")</option>
                    </select>
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="SendMethod_@Model.ModuleId">@L("plSendMethod")</label>
                    </div>
                    <select id="SendMethod_@Model.ModuleId" name="SendMethod">
                        <option value="TO" @(Model.SendMethod == "TO" ? "selected=\"selected\"" : string.Empty)>@L("SendTo")</option>
                        <option value="BCC" @(Model.SendMethod == "BCC" ? "selected=\"selected\"" : string.Empty)>@L("SendBCC")</option>
                        <option value="RELAY" @(Model.SendMethod == "RELAY" ? "selected=\"selected\"" : string.Empty)>@L("SendRelay")</option>
                    </select>
                </div>

                <div class="dnnFormItem relay-address-panel" style="display:@(Model.RelayAddressVisible ? "block" : "none")">
                    <div class="dnnLabel" style="position:relative">
                        <label for="RelayAddress_@Model.ModuleId">@L("plRelayAddress")</label>
                    </div>
                    <input type="text" id="RelayAddress_@Model.ModuleId" name="RelayAddress" maxlength="100" value="@Model.RelayAddress" />
                </div>

                <div class="dnnFormItem">
                    <div class="dnnLabel" style="position:relative">
                        <label for="SendAction_@Model.ModuleId">@L("plSendAction")</label>
                    </div>
                    <div class="dnnNewsletterRadios">
                        <input type="radio" id="Sendaction-S_@Model.ModuleId" name="SendAction" value="S" @(Model.SendAction == "S" ? "checked=\"checked\"" : string.Empty) />
                        <label for="Sendaction-S_@Model.ModuleId">@L("Synchronous")</label>
                        <input type="radio" id="Sendaction-A_@Model.ModuleId" name="SendAction" value="A" @(Model.SendAction == "A" ? "checked=\"checked\"" : string.Empty) />
                        <label for="Sendaction-A_@Model.ModuleId">@L("Asynchronous")</label>
                    </div>
                </div>
            </fieldset>
        </div>

        <div class="commands">
            <div class="dnnLabel" style="position:relative">&#160;</div>
            <div style="display:inline-block;">
                <ul class="dnnActions dnnClear">
                    <li><button type="button" class="dnnPrimaryAction btn-send">@L("cmdSend")</button></li>
                    <li><button type="button" class="dnnSecondaryAction btn-preview">@L("cmdPreview")</button></li>
                    <li class="newsletter-spinner" aria-hidden="true" hidden><span class="newsletter-spinner-icon"></span></li>
                </ul>
            </div>
        </div>

        <div class="preview-panel dnnForm" style="display:none">
            <table>
                <tr>
                    <td style="width:100px; vertical-align:top">@L("Preview")</td>
                    <td style="width:460px;"></td>
                </tr>
                <tr>
                    <td style="width:100px; vertical-align:top">@L("plSubject")</td>
                    <td style="width:460px;" class="preview-subject-content"></td>
                </tr>
                <tr>
                    <td style="width:100px; vertical-align:top">@L("Message")</td>
                    <td style="width:460px;" class="preview-body-content"></td>
                </tr>
            </table>
            <ul class="dnnActions dnnClear">
                <li><button type="button" class="dnnPrimaryAction btn-cancel-preview">@L("cmdCancelPreview")</button></li>
            </ul>
        </div>

    </div>
</div>
